VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL=gemini-2.0-flash

# Email / OTP backend (Outlook SMTP)
SUPPORT_EMAIL=support@cytroksys.in

# Email / OTP backend (Microsoft Graph - Recommended)
GRAPH_TENANT_ID=your_entra_tenant_id
GRAPH_CLIENT_ID=your_app_client_id
GRAPH_CLIENT_SECRET=your_app_client_secret
GRAPH_CLIENT_SECRET_ID=your_app_client_secret_id_optional
GRAPH_SENDER_UPN=support@cytroksys.in

# Email / OTP backend (SMTP fallback)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=support@cytroksys.in
SMTP_PASS=your_outlook_app_password_or_smtp_password
SMTP_FROM="Cytroksys Support <support@cytroksys.in>"

# OTP policy (optional)
CUSTOMER_OTP_TTL_MS=600000
CUSTOMER_OTP_MAX_ATTEMPTS=5
CUSTOMER_SESSION_TTL_MS=86400000

# Optional: needed when Vite runs inside Docker and must reach API container
VITE_API_PROXY_TARGET=http://api:8787

# Firebase (client SDK — safe to expose in frontend)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
