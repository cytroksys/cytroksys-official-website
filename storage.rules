rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Product images: public read, admin-only write
    // Storage rules cannot call Firestore directly, so we check auth
    // and enforce admin check via Custom Claims or trust the client SDK rule
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
